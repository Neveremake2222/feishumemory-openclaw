# Feishu/Lark app credentials. Fill these locally; do not commit real secrets.
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=replace_me_local_secret

# SQLite database used by the memory engine.
MEMORY_ENGINE_DB=memory_engine.sqlite3

# Optional: comma-separated Feishu chat IDs to ingest. Empty means all chats
# visible to the app.
ALLOWED_CHAT_IDS=

# Optional: project registry path for chat -> project mapping.
PROJECT_REGISTRY_PATH=config/project_registry.json

# Feishu proactive reply cards/text are enabled by default in the daemon.
# Set false for ingest-only mode.
MEMORY_REPLY_ENABLED=true

# Optional: local governance ballot reviewer command.
# Example:
# GOVERNANCE_BALLOT_COMMAND_JSON=["python","scripts/sample_governance_ballot.py"]
GOVERNANCE_BALLOT_COMMAND_JSON=

# Optional: real LLM multi-agent governance ballot. When enabled, the same
# OpenAI-compatible endpoint is called by multiple reviewer agents and their
# votes are stored in memory_votes.
GOVERNANCE_LLM_BALLOT_ENABLED=false
GOVERNANCE_LLM_BALLOT_API_BASE=
GOVERNANCE_LLM_BALLOT_API_KEY=
GOVERNANCE_LLM_BALLOT_MODEL=
GOVERNANCE_LLM_BALLOT_TIMEOUT_S=30
# Optional JSON list. Empty uses Evidence/Risk/Utility default agents.
GOVERNANCE_LLM_BALLOT_AGENTS_JSON=

# Optional: actor IDs trusted to report workflow outcome messages.
WORKFLOW_OUTCOME_TRUSTED_ACTOR_IDS=

# Optional: dashboard summary sub-agent. When OPENAI_API_KEY is set, the product
# API rewrites answer summaries with an OpenAI-compatible chat completions API.
SUMMARY_SUBAGENT_ENABLED=true
SUMMARY_SUBAGENT_MODEL=
SUMMARY_SUBAGENT_TIMEOUT_SECONDS=8
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=
